<style>
:root{
  --y1:#fffbf0;--y2:#fff5d5;--y3:#ffe8a0;--y4:#ffd060;
  --o1:#e8720c;--o2:#ff9332;--o4:#fff0e0;
  --w:#ffffff;--k1:#1a1000;--k2:#3d2800;--k3:#7a5a10;--k4:#b89030;
  --g1:#2e7d3a;--g2:#e6f4e8;--p1:#4a1aff;--p2:#ede8ff;
  --r1:#c0392b;--r2:#fdecea;
  --ln:rgba(180,100,0,.12);--ln2:rgba(180,100,0,.22);
  --sh:rgba(200,100,0,.10);--sh2:rgba(200,100,0,.26);
  --rad:18px;--rad2:26px;
}
[data-theme="dark"]{
  --y1:#120c00;--y2:#1e1400;--y3:#2a1c00;--y4:#3a2600;
  --o1:#ff9332;--o2:#ffb060;--o4:#2a1200;
  --w:#201400;--k1:#fff5cc;--k2:#f0d880;--k3:#c09030;--k4:#806010;
  --g1:#5ab864;--g2:#0a2010;--p1:#8060ff;--p2:#1a1040;
  --r1:#e05545;--r2:#280808;
  --ln:rgba(255,180,40,.09);--ln2:rgba(255,180,40,.18);
  --sh:rgba(0,0,0,.4);--sh2:rgba(0,0,0,.65);
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{background:var(--y1);color:var(--k1);font-family:'Nunito',sans-serif;font-size:16px;line-height:1.7;overflow-x:hidden;-webkit-font-smoothing:antialiased;-webkit-tap-highlight-color:transparent;transition:background .3s,color .3s}
a{color:inherit;text-decoration:none}img{display:block;max-width:100%}button{font-family:inherit;cursor:pointer;border:none}
.skip{position:absolute;left:-9999px;top:4px;background:var(--k1);color:var(--y1);padding:8px 16px;border-radius:6px;font-size:13px;font-weight:800;z-index:9999}.skip:focus{left:4px}
.crumbs{position:fixed;inset:0;pointer-events:none;z-index:1;overflow:hidden}
.crumb{position:absolute;animation:crfall linear infinite;opacity:0}
@keyframes crfall{0%{opacity:0;transform:translateY(-80px) rotate(0deg)}8%{opacity:.5}88%{opacity:.5}100%{opacity:0;transform:translateY(108vh) rotate(560deg)}}
@media(max-width:640px){.crumb{display:none}}
@media(prefers-reduced-motion:reduce){.crumb,.hf,.mascot{animation:none!important}}
.hdr{position:sticky;top:0;z-index:100;height:56px;display:flex;align-items:center;justify-content:space-between;padding:0 1rem;background:rgba(255,251,240,.95);backdrop-filter:blur(16px);border-bottom:2px solid var(--ln);transition:background .3s}
[data-theme="dark"] .hdr{background:rgba(18,12,0,.95)}
.logo{font-family:'Fredoka One',cursive;font-size:26px;color:var(--o1);display:flex;align-items:center;gap:5px}
.hdr-r{display:flex;align-items:center;gap:4px}
.nlk{font-size:13px;font-weight:800;color:var(--k3);padding:6px 10px;border-radius:8px;white-space:nowrap;transition:background .12s,color .12s}.nlk:hover{background:var(--y2);color:var(--o1)}
.tog{width:44px;height:26px;flex-shrink:0;background:var(--y3);border:1.5px solid var(--ln2);border-radius:13px;position:relative;transition:background .25s;cursor:pointer}
.tog::after{content:'';position:absolute;top:3px;left:3px;width:16px;height:16px;border-radius:50%;background:var(--o1);transition:transform .25s}
[data-theme="dark"] .tog::after{transform:translateX(18px)}
.ham{display:none;flex-direction:column;gap:5px;background:none;padding:6px;cursor:pointer}
.ham span{display:block;width:22px;height:2.5px;background:var(--k3);border-radius:2px;transition:transform .25s,opacity .25s}
.ham.on span:nth-child(1){transform:translateY(7px) rotate(45deg)}.ham.on span:nth-child(2){opacity:0}.ham.on span:nth-child(3){transform:translateY(-7px) rotate(-45deg)}
@media(max-width:640px){.nlk{display:none}.ham{display:flex}}
.mob{display:none;position:fixed;top:56px;left:0;right:0;z-index:99;background:var(--w);border-bottom:2px solid var(--ln);flex-direction:column;padding:.75rem 1rem 1.25rem;gap:2px;box-shadow:0 8px 32px var(--sh2)}
.mob.on{display:flex;animation:mslide .2s ease}
@keyframes mslide{from{opacity:0;transform:translateY(-8px)}to{opacity:1;transform:none}}
.mob a{font-size:15px;font-weight:800;color:var(--k2);padding:12px 14px;border-radius:10px;border-bottom:1px solid var(--ln);transition:background .1s;display:flex;align-items:center;gap:8px}
.mob a:last-child{border-bottom:none}.mob a:hover{background:var(--y2)}
.mob .mhot{background:var(--o1);color:#fff;border-radius:10px;border-bottom:none;margin-top:8px;justify-content:center;font-family:'Fredoka One',cursive;font-size:16px}
.rv{opacity:0;transform:translateY(22px);transition:opacity .65s ease,transform .65s ease}.rv.in{opacity:1;transform:none}
.w{max-width:820px;margin:0 auto;padding:0 1rem;position:relative;z-index:2}
section{padding:2.5rem 0}
.btn{display:inline-flex;align-items:center;justify-content:center;gap:8px;font-family:'Fredoka One',cursive;font-size:18px;letter-spacing:.5px;padding:15px 30px;border-radius:50px;border:none;cursor:pointer;transition:transform .12s,box-shadow .15s;-webkit-tap-highlight-color:transparent;min-height:52px;text-decoration:none}
.btn:active{transform:scale(.95)!important}
.btn-o{background:var(--o1);color:#fff;box-shadow:0 6px 22px var(--sh2)}.btn-o:hover{transform:translateY(-2px) scale(1.02)}
.btn-y{background:var(--y4);color:var(--k2);box-shadow:0 4px 14px var(--sh)}.btn-y:hover{transform:translateY(-2px) scale(1.02)}
.btn-p{background:var(--p1);color:#fff}.btn-p:hover{transform:translateY(-2px) scale(1.02)}
@media(max-width:480px){.btn{font-size:16px;padding:13px 22px;min-height:52px;width:100%}}
.btn-auto{width:auto!important}
.hero{position:relative;min-height:520px;overflow:hidden;background:linear-gradient(155deg,#ffb030 0%,#e8720c 40%,#b84000 75%,#7a2000 100%)}
@media(max-width:640px){.hero{min-height:420px}}
.hero-shade{position:absolute;inset:0;z-index:1;background:linear-gradient(to top,rgba(6,2,0,.82) 0%,rgba(6,2,0,.35) 50%,rgba(0,0,0,.05) 100%)}
.hero-floats{position:absolute;inset:0;z-index:2;pointer-events:none;overflow:hidden}
.hf{position:absolute;animation:hfloat ease-in-out infinite;opacity:.75;line-height:1}
@keyframes hfloat{0%,100%{transform:translateY(0) rotate(-6deg)}50%{transform:translateY(-18px) rotate(6deg)}}
.mascot{position:absolute;bottom:0;right:4%;z-index:3;width:min(220px,35vw);pointer-events:none;animation:mbob 3s ease-in-out infinite}
@keyframes mbob{0%,100%{transform:translateY(0) rotate(-2deg)}50%{transform:translateY(-12px) rotate(2deg)}}
@media(max-width:480px){.mascot{width:min(160px,38vw);right:1%}}
.mascot img{width:100%;height:auto;filter:drop-shadow(0 8px 28px rgba(0,0,0,.45))}
.hero-text{position:absolute;bottom:0;left:0;z-index:4;padding:2.5rem 1.25rem 3rem;max-width:520px}
.hero-eyebrow{font-family:'Fredoka One',cursive;font-size:clamp(11px,2.5vw,14px);color:#ffe8b0;letter-spacing:.12em;text-transform:uppercase;margin-bottom:.4rem;display:flex;align-items:center;gap:8px}
.hero-eyebrow::before{content:'';width:20px;height:2px;background:#ffe8b0;flex-shrink:0}
.hero-h1{font-family:'Fredoka One',cursive;font-size:clamp(58px,14vw,108px);line-height:.88;letter-spacing:4px;color:#fff;text-shadow:4px 4px 0 rgba(0,0,0,.3),0 0 60px rgba(255,180,0,.5);margin-bottom:.5rem}
.hero-sub{font-family:'Fredoka One',cursive;font-size:clamp(14px,3.2vw,21px);color:#ffe8b0;margin-bottom:1.5rem;line-height:1.3}
.hero-btns{display:flex;flex-wrap:wrap;gap:10px}
@media(max-width:480px){.hero-btns .btn{width:calc(50% - 5px)}}
@media(max-width:360px){.hero-btns .btn{width:100%}}
.streak{background:var(--o4);border:2px solid rgba(232,114,12,.2);border-radius:var(--rad2);padding:1rem 1.25rem;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:.75rem;margin-bottom:2rem}
.snum{font-family:'Fredoka One',cursive;font-size:44px;color:var(--o1);line-height:1}
.sinfo{font-size:13.5px;font-weight:700;color:var(--k3);line-height:1.5}
.sh{font-family:'Fredoka One',cursive;font-size:clamp(26px,5.5vw,40px);color:var(--o1);margin-bottom:1rem;line-height:1.15}
.ruled{display:flex;align-items:center;gap:12px;margin:3rem 0;font-family:'Fredoka One',cursive;font-size:15px;color:var(--k4)}
.ruled::before,.ruled::after{content:'';flex:1;height:2px;background:linear-gradient(90deg,transparent,var(--ln),transparent)}
.pgrid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:1.5rem}
.pgrid>div{border-radius:var(--rad);overflow:hidden;aspect-ratio:1;min-height:140px}
.steps{display:flex;flex-direction:column;gap:12px}
.step{background:var(--w);border:2px solid var(--ln2);border-radius:var(--rad2);padding:1.25rem 1.35rem;display:flex;gap:1rem;align-items:flex-start;box-shadow:0 3px 14px var(--sh);transition:transform .15s,box-shadow .15s}
.step:hover{transform:translateY(-2px);box-shadow:0 8px 24px var(--sh2)}
.sn{width:46px;height:46px;flex-shrink:0;background:var(--o1);color:#fff;border-radius:14px;font-family:'Fredoka One',cursive;font-size:21px;display:flex;align-items:center;justify-content:center;box-shadow:0 3px 10px var(--sh2)}
.stit{font-size:17px;font-weight:900;color:var(--k1);margin-bottom:.35rem}
.sbod{font-size:14px;font-weight:600;color:var(--k3);line-height:1.65}
.tip{margin-top:.65rem;background:var(--y2);border-radius:10px;padding:.5rem .9rem;font-size:13px;font-weight:700;color:var(--k2);border-left:3px solid var(--o2)}
.aigrid{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:12px}
@media(max-width:560px){.aigrid{grid-template-columns:1fr}}
.aic{background:var(--w);border:2px solid var(--ln2);border-radius:var(--rad2);padding:1.4rem;box-shadow:0 4px 16px var(--sh);transition:transform .15s,box-shadow .15s;display:flex;flex-direction:column;gap:.35rem}
.aic:hover{transform:translateY(-3px);box-shadow:0 10px 28px var(--sh2)}
.aic.me{border-color:var(--o1);border-width:3px}
.aname{font-family:'Fredoka One',cursive;font-size:22px;color:var(--k1)}
.avibe{font-size:11px;font-weight:900;text-transform:uppercase;letter-spacing:.09em;color:var(--o1)}
.adesc{font-size:13.5px;font-weight:600;color:var(--k3);line-height:1.65;flex:1}
.atip{background:var(--y2);border-radius:10px;padding:.55rem .85rem;font-size:12.5px;font-weight:700;color:var(--k2)}
.alb{display:inline-flex;align-items:center;gap:5px;align-self:flex-start;font-size:13px;font-weight:900;color:var(--o1);padding:7px 16px;border:2px solid var(--o1);border-radius:20px;transition:background .12s,color .12s;min-height:40px}
.alb:hover{background:var(--o1);color:#fff}
.plbl{font-size:13px;font-weight:900;color:var(--k3);margin-bottom:.55rem;display:flex;align-items:center;gap:6px}
.pbox{background:var(--y2);border:2px dashed var(--ln2);border-radius:12px;padding:.9rem 1rem;font-size:14px;font-weight:700;color:var(--k2);line-height:1.7;margin-bottom:.85rem;white-space:pre-wrap;word-break:break-word}
.pbtn{display:inline-flex;align-items:center;gap:6px;background:var(--o1);color:#fff;font-family:'Fredoka One',cursive;font-size:14px;padding:10px 20px;border-radius:20px;transition:transform .1s,background .12s;min-height:44px;cursor:pointer;border:none}
.pbtn:hover{transform:scale(1.04)}.pbtn.ok{background:var(--g1)}
.pcard{background:var(--w);border:2px solid var(--ln2);border-radius:var(--rad2);padding:1.4rem;margin-bottom:12px;box-shadow:0 3px 12px var(--sh)}
.psec{font-family:'Fredoka One',cursive;font-size:20px;color:var(--k2);margin:1.5rem 0 .75rem;display:flex;align-items:center;gap:8px}
.egrid{display:grid;grid-template-columns:1fr 1fr;gap:10px}
@media(max-width:480px){.egrid{grid-template-columns:1fr}}
.ec{border-radius:var(--rad);padding:1.1rem 1.2rem}
.ec.g{background:var(--g2);border:2px solid rgba(46,125,58,.2)}.ec.b{background:var(--r2);border:2px solid rgba(192,57,43,.18)}
.eclbl{font-size:11px;font-weight:900;text-transform:uppercase;letter-spacing:.08em;margin-bottom:.4rem}
.ec.g .eclbl{color:var(--g1)}.ec.b .eclbl{color:var(--r1)}
.ectxt{font-size:14px;font-weight:700;color:var(--k2);line-height:1.6}
.mbox{background:var(--w);border:2px solid var(--ln2);border-radius:var(--rad2);overflow:hidden;box-shadow:0 4px 16px var(--sh)}
.mhd{padding:1rem 1.25rem;border-bottom:2px solid var(--ln);display:flex;align-items:center;justify-content:space-between}
.mhdl{font-family:'Fredoka One',cursive;font-size:17px;color:var(--k2)}.mpct{font-size:14px;font-weight:900;color:var(--g1)}
.mbar{height:5px;background:var(--y3)}.mfill{height:100%;background:var(--g1);transition:width .4s ease;border-radius:3px}
.mi{display:flex;align-items:flex-start;gap:12px;padding:14px 18px;border-bottom:1px solid var(--ln);cursor:pointer;user-select:none;transition:background .1s;min-height:56px}
.mi:last-of-type{border-bottom:none}.mi:hover{background:var(--y1)}
.mcb{width:22px;height:22px;flex-shrink:0;margin-top:2px;border:2.5px solid var(--ln2);border-radius:6px;display:flex;align-items:center;justify-content:center;font-size:13px;color:#fff;transition:background .15s,border-color .15s}
.mi.dn .mcb{background:var(--g1);border-color:var(--g1)}.mi.dn .mt{text-decoration:line-through;color:var(--k4)}
.mt{font-size:15px;font-weight:700;color:var(--k2);line-height:1.55}
.mft{padding:10px 18px;border-top:1px solid var(--ln)}
.mbtn{font-size:13px;font-weight:800;color:var(--k3);background:var(--y1);border:1.5px solid var(--ln2);border-radius:10px;padding:8px 16px;min-height:44px;cursor:pointer}
.mbtn:hover{background:var(--y2)}
.ngrid{display:grid;grid-template-columns:repeat(auto-fill,minmax(230px,1fr));gap:12px}
@media(max-width:480px){.ngrid{grid-template-columns:1fr}}
.ncard{background:var(--w);border:2px solid var(--ln2);border-radius:var(--rad2);padding:1.35rem;box-shadow:0 4px 14px var(--sh);transition:transform .15s,box-shadow .15s;display:flex;flex-direction:column;gap:.5rem}
.ncard:hover{transform:translateY(-3px);box-shadow:0 10px 26px var(--sh2)}
.ncard.astro{border-color:var(--p1);border-width:3px}
.nico{font-size:34px;line-height:1}.nname{font-family:'Fredoka One',cursive;font-size:19px;color:var(--k1)}
.ncard.astro .nname{color:var(--p1)}
.ndesc{font-size:13px;font-weight:600;color:var(--k3);line-height:1.6;flex:1}
.nlnk{display:inline-flex;align-items:center;gap:5px;align-self:flex-start;font-size:13px;font-weight:900;color:var(--o1);padding:7px 14px;border:2px solid var(--o1);border-radius:16px;transition:background .12s,color .12s;min-height:40px}
.nlnk:hover{background:var(--o1);color:#fff}
.ncard.astro .nlnk{color:var(--p1);border-color:var(--p1)}.ncard.astro .nlnk:hover{background:var(--p1);color:#fff}
.aspot{background:var(--p2);border:3px solid rgba(74,26,255,.25);border-radius:var(--rad2);padding:2rem 1.5rem;text-align:center;margin-top:1.5rem}
.donate{background:var(--g2);border:2px solid rgba(46,125,58,.2);border-radius:var(--rad2);padding:2rem 1.5rem;text-align:center}
.dbtns{display:flex;gap:10px;flex-wrap:wrap;justify-content:center;margin-top:1.1rem}
.dbtn{display:inline-flex;align-items:center;gap:6px;font-size:14px;font-weight:800;padding:11px 20px;border-radius:20px;background:var(--w);border:2px solid rgba(46,125,58,.22);color:var(--k1);transition:background .12s,transform .1s;min-height:46px}
.dbtn:hover{background:var(--y3);transform:translateY(-1px)}
footer{max-width:820px;margin:0 auto;padding:2.5rem 1rem 3rem;border-top:2px solid var(--ln);text-align:center;position:relative;z-index:2}
.ftitle{font-family:'Fredoka One',cursive;font-size:28px;color:var(--o1);margin-bottom:.4rem}
.flinks{display:flex;flex-wrap:wrap;gap:10px;justify-content:center;margin-bottom:1.25rem}
.flinks a{font-size:13px;font-weight:800;color:var(--k4);padding:5px 10px;border-radius:8px;transition:color .1s,background .1s}
.flinks a:hover{color:var(--o1);background:var(--y2)}
.fshare{background:#000;color:#fff;font-family:'Fredoka One',cursive;font-size:17px;padding:13px 28px;border-radius:50px;margin-bottom:1.1rem;transition:transform .12s;min-height:50px;cursor:pointer;border:none}
.fshare:hover{transform:scale(1.05)}
.ftag{font-size:13px;font-weight:600;color:var(--k3)}
#btt{display:none;position:fixed;bottom:calc(16px + env(safe-area-inset-bottom,0px));right:16px;z-index:90;width:50px;height:50px;border-radius:50%;background:var(--o1);color:#fff;font-size:22px;box-shadow:0 4px 18px var(--sh2);align-items:center;justify-content:center;transition:opacity .2s,transform .15s;cursor:pointer;border:none}
#btt:hover{transform:scale(1.1)}
#confetti{position:fixed;inset:0;pointer-events:none;z-index:9999}
/* code download button */
.code-download{display:flex;align-items:center;gap:8px;background:var(--o1);color:#fff;font-family:'Fredoka One',cursive;font-size:16px;padding:13px 24px;border-radius:50px;border:none;cursor:pointer;box-shadow:0 4px 18px var(--sh2);transition:transform .12s;text-decoration:none;min-height:50px}
.code-download:hover{transform:scale(1.05)}
</style>
</head>
